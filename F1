#include <iostream>
using namespace std;

int main()
{
    int type;
    int size;
    char texture;

    cout << "[+] Фигура: \"Четверть квадрата\"" << endl << endl;

    cout << "[1] Заполненный" << endl;
    cout << "[2] Пустой" << endl << endl;

    cout << "[+] Выберите тип: ";
    cin >> type;

    cout << endl << "[+] Размер: ";
    cin >> size;

    cout << endl << "[+] Текстура: ";
    cin >> texture;

    cout << endl << "[+] Результат:" << endl << endl;

    for (int i = 0; i < size; i++)
    {
        for (int j = 0; j < size; j++)
        {
            if (i >= size / 2 && j >= size / 2)
            {
                if (type == 1)
                {
                    cout << texture << " ";
                }
                else
                {
                    if (i == size / 2 || j == size / 2 || i == size - 1 || j == size - 1)
                        cout << texture << " ";
                    else
                        cout << "  ";
                }
            }
            else
            {
                cout << ". ";
            }
        }
        cout << endl;
    }

    return 0;
}
